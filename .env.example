NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM — Groq primary, OpenRouter fallback
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional: embeddings for semantic workflow matching (Feature 10).
# Set ONE of these (both have free tiers). Without a key the agent falls back
# to keyword matching automatically.
GEMINI_API_KEY=
JINA_API_KEY=

BRAVE_SEARCH_API_KEY=
CRON_SECRET=
CONNECTOR_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
