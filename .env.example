# ── Supabase ──────────────────────────────────────────────
# Project URL + publishable (anon) key: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# service_role secret key — server-side agent writes, bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Access lock ───────────────────────────────────────────
# The ONLY email allowed to sign in. Required — if unset, nobody can log in.
NEXT_PUBLIC_ALLOWED_EMAIL=you@example.com

# ── LLM (Groq primary, OpenRouter fallback) ───────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Embeddings (optional) ─────────────────────────────────
# Enables semantic workflow matching (Feature 10). Set ONE — both have free
# tiers. Without a key the agent falls back to keyword matching automatically.
GEMINI_API_KEY=
JINA_API_KEY=

# ── Web search ────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=

# ── Security ──────────────────────────────────────────────
# Protects /api/agent/run from public access. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
CONNECTOR_ENCRYPTION_KEY=

# ── Google OAuth (optional — Gmail + Calendar tools) ──────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email notifications (optional) ────────────────────────
RESEND_API_KEY=
